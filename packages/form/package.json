{
  "name": "@cogitant/react-form",
  "version": "1.0.0",
  "description": "Flexible form handling for React with validation support",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./components": {
      "types": "./dist/components/form.d.ts",
      "import": "./dist/components/form.js",
      "require": "./dist/components/form.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/components/form.tsx --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/components/form.tsx --format cjs,esm --dts --watch",
    "test": "vitest run"
  },
  "keywords": ["form", "validation", "react", "hooks", "zod"],
  "author": "cogitant",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cogitant/universal-admin.git",
    "directory": "packages/form"
  },
  "bugs": {
    "url": "https://github.com/cogitant/universal-admin/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "sideEffects": false
}
