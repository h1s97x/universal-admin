{
  "name": "@cogitant/api-client",
  "version": "1.0.0",
  "description": "A type-safe, flexible API client with caching, retry, and error handling",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client/api-client.d.ts",
      "import": "./dist/client/api-client.js",
      "require": "./dist/client/api-client.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/client/*.ts src/hooks/*.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/client/*.ts src/hooks/*.ts --format cjs,esm --dts --clean --watch",
    "test": "vitest"
  },
  "keywords": ["api", "client", "fetch", "http", "request", "react", "hooks"],
  "author": "cogitant",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cogitant/universal-admin.git",
    "directory": "packages/api-client"
  },
  "bugs": {
    "url": "https://github.com/cogitant/universal-admin/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "sideEffects": false
}
